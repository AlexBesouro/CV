.pair{
    display: grid;
    grid-template-columns: 240px 1fr;
    height: 300px;
    gap: 20px;
    align-items: stretch;
}

.experience-cars .auto {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    display: block;
}

.experience-cars .auto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(0.95);
}

.experience-table {
    width: 100%;
    height: 100%;
    border-collapse: separate;
    border-spacing: 10px;    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
}

.experience-table::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent);
    border-radius: 2px 0 0 2px;
    opacity: 0;
    transition: var(--transition);
}

.experience-table:hover {
    border-color: #3a3a3a;
    transform: translateY(-2px);
}

.experience-table:hover::before {
    opacity: 1;
}

.experience-table th,
.experience-table td {
    padding: 10px 20px;
    text-align: left;
    vertical-align: center;
    border-bottom: 1px solid var(--accent);
    font-size: 0.9rem;
}

.experience-table tbody tr:last-child th,
.experience-table tbody tr:last-child td {
    border-bottom: none;
}

.experience-table th {
    color: var(--text);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
    width: 1%;
    padding-right: 16px;
}

/* Position — крупно как card-role */
.experience-table tr:first-child td {
    font-family: var(--font-head);
    font-size: 1.2rem;
    font-weight: 700;
}

/* Entreprise — цветом акцента */
.experience-table tr:nth-child(2) td {
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.04em;
}

/* Période — курсив и muted */
.experience-table tr:nth-child(3) td {
    color: var(--muted);
    font-style: italic;
    font-size: 0.82rem;
}

/* Missions — список */
.experience-table ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.experience-table ul li {
    font-size: 0.92rem;
    color: #aaa;
    padding-left: 16px;
    position: relative;
}

.experience-table ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.8rem;
    top: 2px;
}

/* ── Секция Antonov ── */
.experience-antonov {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 24px;
    align-items: start;
}

.experience-antonov .plane {
    order: -1;
    /* таблица слева, картинка справа — меняем порядок если нужно */
}

/* Перекладываем: таблица слева, картинка справа */
.experience-antonov {
    grid-template-columns: 1fr 220px;
}

.experience-antonov .experience-table {
    order: 1;
}

.experience-antonov .plane {
    order: 2;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    display: block;
    height: 100%;
}

.experience-antonov .plane img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}